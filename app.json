{
  "expo": {
    "name": "SmartRoute",
    "slug": "smartroute-delivery-system",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartroute.app",
      "infoPlist": {
        "NSCameraUsageDescription": "SmartRoute needs camera access to scan package QR codes.",
        "NSLocationWhenInUseUsageDescription": "SmartRoute needs your location to optimize delivery routes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.smartroute.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "SmartRoute needs camera access to scan package QR codes."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SmartRoute needs location access to optimize your delivery route."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2563EB",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c3676aa6-f301-4501-8af0-edfd2d9d6b7f"
      }
    },
    "owner": "aiden270s-team"
  }
}
